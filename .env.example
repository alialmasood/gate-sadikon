# انسخ هذا الملف إلى .env أو .env.local وعدّل القيم.
# لا ترفع ملف .env أو .env.local إلى Git.

# قاعدة البيانات (مطلوب)
DATABASE_URL="postgresql://user:password@localhost:5432/gate_sadikon"

# NextAuth (مطلوب لتسجيل الدخول والجلسات)
NEXTAUTH_SECRET="غيّر_هذا_إلى_نص_عشوائي_طويل"
NEXTAUTH_URL="http://localhost:3000"

# مفتاح صفحة إدارة النظام /system — أدخل هذا المفتاح في الصفحة لإنشاء سوبر أدمن
# (يجب 8 أحرف على الأقل؛ للتطوير يمكن استخدام 123456789)
SYSTEM_SETUP_SECRET="123456789"

# اختياري: إنشاء أول سوبر أدمن من سكربت (npm run create-super-admin)
# FIRST_SUPER_ADMIN_EMAIL="admin@example.com"
# FIRST_SUPER_ADMIN_PASSWORD="كلمة_مرور_8_أحرف_على_الأقل"
# FIRST_SUPER_ADMIN_NAME="مدير النظام"
